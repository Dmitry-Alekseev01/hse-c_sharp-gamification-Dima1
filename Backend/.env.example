# .env.example - copy to .env and edit before running

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=replace-me

# Postgres (used to construct DATABASE_URL automatically if DATABASE_URL is not set)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Optional full DATABASE_URL (if set, it will be used instead of the above components)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/app_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
DB_POOL_PRE_PING=true

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# CORS
CORS_ALLOW_ORIGINS=http://localhost:3002,http://127.0.0.1:3002,http://localhost:8080,http://127.0.0.1:8080
CORS_ALLOW_CREDENTIALS=true

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_DEFAULT=300
RATE_LIMIT_AUTH=20
RATE_LIMIT_ANSWERS=180
RATE_LIMIT_ANALYTICS=120
RATE_LIMIT_AI=30

SECRET_KEY=replace-this-with-a-secure-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Where token endpoint lives (used by OAuth2PasswordBearer)
OAUTH2_TOKEN_URL=/api/v1/auth/token

# Hash schemes used by passlib (comma-separated if needed)
HASH_SCHEMES=bcrypt

# AI gamification (OpenRouter)
AI_GAMIFICATION_ENABLED=false
AI_GAMIFICATION_DAILY_QUOTA_PER_USER=20
AI_GAMIFICATION_MAX_SOURCE_CHARS=12000
AI_GAMIFICATION_JOB_MAX_RETRIES=2
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/free
# Comma-separated fallback list, example:
# OPENROUTER_FALLBACK_MODELS=deepseek/deepseek-r1:free,qwen/qwen3-coder:free,qwen/qwen3-4b:free
OPENROUTER_FALLBACK_MODELS=deepseek/deepseek-r1:free,qwen/qwen3-coder:free,qwen/qwen3-4b:free
OPENROUTER_TIMEOUT_SECONDS=30
OPENROUTER_MAX_RETRIES=2
# Optional attribution headers (recommended by OpenRouter):
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=hse-c-sharp-gamification
